FROM langchain/langgraph-api:3.11

ADD ./shared /deps/shared
ADD ./planner /deps/planner
ADD ./worker /deps/worker
ADD ./config.yaml /deps/config.yaml
ADD ./prompts.yaml /deps/prompts.yaml
ADD ./context.yaml /deps/context.yaml

RUN PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt -e /deps/planner && \
    PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt -e /deps/worker

ENV LANGSERVE_GRAPHS='{"planner_graph": "/deps/planner/main.py:graph", "worker_graph": "/deps/worker/main.py:graph"}'
ENV CONFIG_PATH=/deps/config.yaml
ENV PROMPTS_PATH=/deps/prompts.yaml
ENV CONTEXT_PATH=/deps/context.yaml

RUN mkdir -p /api/langgraph_api /api/langgraph_runtime /api/langgraph_license && \
    touch /api/langgraph_api/__init__.py /api/langgraph_runtime/__init__.py /api/langgraph_license/__init__.py
RUN PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir --no-deps -e /api
