# ============================================================
# A2A Agent System — Environment Variables
# Copy to .env and fill in ONE provider key.
# ============================================================

# ── Recommended: Groq (fast, free, no credit card) ──────────
# Sign up: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_key_here

# ── Alternative: Google Gemini (free tier) ───────────────────
# Get key: https://aistudio.google.com/app/apikey
# Then set provider: gemini  model_id: gemini-1.5-flash  in config.yaml
# GEMINI_API_KEY=your_gemini_key_here

# ── Alternative: OpenRouter (has :free models) ───────────────
# Sign up: https://openrouter.ai → Keys
# Then set provider: openrouter  model_id: meta-llama/llama-3.1-8b-instruct:free  in config.yaml
# OPENROUTER_API_KEY=your_openrouter_key_here

# ── Alternative: Ollama (fully local, no key needed) ─────────
# Run: ollama serve && ollama pull llama3.1
# Then set provider: ollama  model_id: llama3.1  in config.yaml
# OLLAMA_URL=http://localhost:11434

# ── A2A Bearer Auth Tokens ───────────────────────────────────
# Change these in production. Both agents accept all listed tokens.
PLANNER_TOKEN=planner-dev-token
WORKER_TOKEN=worker-dev-token

# ── Tools (optional) ─────────────────────────────────────────
# For web_search tool: get a free key at https://brave.com/search/api/
# BRAVE_API_KEY=your_brave_key_here

# ── Agent URLs (set automatically by docker-compose) ─────────
# Only needed for local dev without Docker:
# WORKER_URL=http://localhost:8001
# PLANNER_PUBLIC_URL=http://localhost:8000
# WORKER_PUBLIC_URL=http://localhost:8001
